# Production configuration template. Copy selected values into your real .env.
# Never commit real secrets.

RI_FOLDERS=category-a
RI_IMAGE_ROOT=images
RI_ALLOWED_HOSTS=example.com,www.example.com
RI_TRUST_PROXY=true
RI_DEFAULT_MODE=redirect

# Generate with: php bin/console.php generate-token
RI_ADMIN_ENABLED=false
RI_ADMIN_TOKEN=
RI_ADMIN_ALLOW_QUERY_TOKEN=false

RI_INDEX_DATABASE=.runtime/image-index.sqlite
RI_INDEX_LOCK=.runtime/index.lock
RI_INDEX_LOG=.runtime/index.log
RI_INDEX_LOG_MAX_BYTES=1048576
RI_INDEX_LOG_BACKUPS=3

RI_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.avif,.bmp
RI_ALLOW_SVG=false
RI_MAX_IMAGE_BYTES=52428800

# Remote links stay disabled until this allowlist is set and check-links succeeds.
RI_LINKCHECK_ALLOWED_HOSTS=
RI_REMOTE_REQUIRE_CHECKED=true
RI_REMOTE_CHECK_MAX_AGE=86400
RI_LINKCHECK_VERIFY_TLS=true
# Requires cURL when no RI_HTTP_PROXY is configured.
RI_LINKCHECK_BIND_RESOLVED_IP=true
RI_LINKCHECK_TIMEOUT=5
RI_LINKCHECK_CONCURRENCY=4
RI_LINKCHECK_USER_AGENT=random-image-api/1.0
RI_HTTP_PROXY=

RI_SENDFILE_MODE=php
RI_X_ACCEL_PREFIX=
