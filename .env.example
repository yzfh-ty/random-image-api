# Optional runtime overrides. Copy to .env for local use.
# Real system environment variables take precedence over values in .env.

# Core
# RI_FOLDERS=erciyuan,fengjing
# RI_IMAGE_ROOT=images
# RI_LINK_FILES=links.txt
# RI_DEFAULT_MODE=redirect

# Server and reverse proxy
# RI_SERVER_HOST=0.0.0.0
# RI_SERVER_PORT=3000
# RI_ALLOWED_HOSTS=example.com,www.example.com
# RI_TRUST_PROXY=false

# Admin API
# RI_ADMIN_ENABLED=false
# RI_ADMIN_PREFIX=/_api
# RI_ADMIN_TOKEN=
# RI_ADMIN_ALLOW_QUERY_TOKEN=false

# Index storage
# RI_INDEX_DATABASE=.runtime/image-index.sqlite
# RI_INDEX_LOCK=.runtime/index.lock
# RI_INDEX_LOG=.runtime/index.log

# Images
# RI_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.avif,.bmp
# RI_ALLOW_SVG=false

# Remote link checks
# RI_HTTP_PROXY=
# RI_LINKCHECK_TIMEOUT=5
# RI_LINKCHECK_USER_AGENT=random-image-api/1.0
# RI_LINKCHECK_VERIFY_TLS=true
# RI_LINKCHECK_ALLOWED_HOSTS=

# Local image output
# RI_SENDFILE_MODE=php
# RI_X_ACCEL_PREFIX=
