# Runtime configuration. Copy this file to .env for local use.
# Real system environment variables take precedence over values in .env.

# Core
# Comma-separated top-level image categories that are allowed to be requested.
# Example: RI_FOLDERS=erciyuan,fengjing
RI_FOLDERS=erciyuan

# Local image root directory, relative to the project root unless absolute.
# RI_IMAGE_ROOT=images

# TXT file names read from each configured category for remote image links.
# RI_LINK_FILES=links.txt

# Default response mode: redirect returns 302, json returns JSON without requiring ?json=1.
# RI_DEFAULT_MODE=redirect

# Server and reverse proxy
# PHP built-in server bind host used by Docker/local startup scripts.
# RI_SERVER_HOST=0.0.0.0

# PHP built-in server port used by Docker/local startup scripts.
# RI_SERVER_PORT=3000

# Allowed request Host headers. Replace with your production domains before deployment.
RI_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]

# Trust X-Forwarded-Proto and X-Forwarded-Host from a reverse proxy.
# Enable only when the app is behind a trusted proxy.
# RI_TRUST_PROXY=false

# Admin API
# Enable read-only admin status endpoints under RI_ADMIN_PREFIX.
# RI_ADMIN_ENABLED=false

# Admin route prefix. This value is also reserved and cannot be used as a category.
# RI_ADMIN_PREFIX=/_api

# Bearer token required when admin API is enabled. Use at least 32 random characters.
# RI_ADMIN_TOKEN=

# Allow admin token in ?token=. Disabled by default to avoid leaking tokens in logs.
# RI_ADMIN_ALLOW_QUERY_TOKEN=false

# Index storage
# SQLite index database path.
# RI_INDEX_DATABASE=.runtime/image-index.sqlite

# File lock path used to prevent concurrent index rebuilds.
# RI_INDEX_LOCK=.runtime/index.lock

# JSONL index log path.
# RI_INDEX_LOG=.runtime/index.log

# Rotate index log when it reaches this many bytes. Use 0 to disable size rotation.
# RI_INDEX_LOG_MAX_BYTES=1048576

# Number of rotated index log backups to keep.
# RI_INDEX_LOG_BACKUPS=3

# Images
# Allowed local image extensions. SVG is ignored unless RI_ALLOW_SVG=true.
# RI_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.avif,.bmp

# Allow SVG indexing/output. Keep false unless you understand scriptable SVG risks.
# RI_ALLOW_SVG=false

# Maximum local image file size in bytes. Use 0 to disable this size limit.
# RI_MAX_IMAGE_BYTES=52428800

# Remote links must pass check-links before short URLs can redirect to them.
# RI_REMOTE_REQUIRE_CHECKED=true

# Maximum age in seconds for a successful remote link check.
# RI_REMOTE_CHECK_MAX_AGE=86400

# Remote link checks
# Optional HTTP proxy for checking remote links, for example http://127.0.0.1:10808.
# RI_HTTP_PROXY=

# Timeout in seconds for each remote link check.
# RI_LINKCHECK_TIMEOUT=5

# Maximum concurrent remote link checks when cURL is available.
# RI_LINKCHECK_CONCURRENCY=4

# User-Agent sent during remote link checks.
# RI_LINKCHECK_USER_AGENT=random-image-api/1.0

# Verify TLS certificates when checking HTTPS remote links.
# RI_LINKCHECK_VERIFY_TLS=true

# Bind cURL requests to the public IP resolved during validation when no proxy is used.
# With this enabled and no proxy configured, remote checks require cURL.
# RI_LINKCHECK_BIND_RESOLVED_IP=true

# Comma-separated allowlist for remote image hosts. Remote links are disabled when empty.
# Example: RI_LINKCHECK_ALLOWED_HOSTS=example.com,*.example.org
# RI_LINKCHECK_ALLOWED_HOSTS=

# Local image output
# Local image output mode: php, x-sendfile, or x-accel.
# RI_SENDFILE_MODE=php

# Internal Nginx location prefix required when RI_SENDFILE_MODE=x-accel.
# RI_X_ACCEL_PREFIX=
